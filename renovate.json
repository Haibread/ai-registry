{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "UTC",
  "schedule": ["before 6am on Monday"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Group all Go dependencies",
      "matchManagers": ["gomod"],
      "groupName": "Go dependencies",
      "groupSlug": "go-deps"
    },
    {
      "description": "Group npm patch and minor updates",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "Node dependencies (patch/minor)",
      "groupSlug": "node-deps-safe"
    },
    {
      "description": "Group Docker base images",
      "matchManagers": ["dockerfile"],
      "groupName": "Docker base images",
      "groupSlug": "docker-images"
    },
    {
      "description": "Group docker-compose images",
      "matchManagers": ["docker-compose"],
      "groupName": "Docker Compose images",
      "groupSlug": "docker-compose-images"
    },
    {
      "description": "Keep next and eslint-config-next in sync (versions must always match)",
      "matchManagers": ["npm"],
      "matchPackageNames": ["next", "eslint-config-next"],
      "groupName": "Next.js",
      "groupSlug": "nextjs"
    },
    {
      "description": "Group Tailwind CSS ecosystem — major requires manual CSS config migration",
      "matchManagers": ["npm"],
      "matchPackageNames": ["tailwindcss", "tailwind-merge", "autoprefixer", "tailwindcss-animate"],
      "groupName": "Tailwind CSS",
      "groupSlug": "tailwind"
    },
    {
      "description": "next-auth v5 beta — follow beta channel, do not downgrade to v4 stable",
      "matchManagers": ["npm"],
      "matchPackageNames": ["next-auth"],
      "versioning": "npm",
      "ignoreUnstable": false,
      "allowedVersions": ">=5.0.0-beta.0"
    },
    {
      "description": "Keep @types/node pinned to the same major as the Node.js runtime (22)",
      "matchManagers": ["npm"],
      "matchPackageNames": ["@types/node"],
      "allowedVersions": "^22.0.0"
    },
    {
      "description": "openapi-typescript peer-dep declares typescript ^5.x — group with typescript so they upgrade together and the .npmrc note stays accurate",
      "matchManagers": ["npm"],
      "matchPackageNames": ["typescript", "openapi-typescript"],
      "groupName": "TypeScript + openapi-typescript",
      "groupSlug": "typescript-openapi",
      "automerge": false
    },
    {
      "description": "Automerge patch and minor Go updates",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Automerge patch and minor npm updates",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Require manual merge for major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Pin GitHub Actions to digest",
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "groupName": "GitHub Actions",
      "groupSlug": "github-actions"
    },
    {
      "description": "OTel packages — keep in sync",
      "matchManagers": ["gomod"],
      "groupName": "OpenTelemetry Go",
      "groupSlug": "otel-go",
      "matchPackageNames": [
        "go.opentelemetry.io/{/,}**"
      ]
    },
    {
      "description": "testcontainers updates — manual review",
      "matchManagers": ["gomod"],
      "matchPackageNames": [
        "github.com/testcontainers/testcontainers-go",
        "github.com/testcontainers/testcontainers-go/modules/postgres"
      ],
      "automerge": false,
      "groupName": "testcontainers",
      "groupSlug": "testcontainers"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "dependencies"]
  },
  "osvVulnerabilityAlerts": true
}
