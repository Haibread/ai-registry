{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-registry.example/schemas/a2a-agent-card.schema.json",
  "title": "A2A Agent Card",
  "description": "Minimal JSON Schema for the A2A (Agent-to-Agent) Agent Card document as pinned by CLAUDE.md Resolved Decision G: the a2a-project/a2a shape at the June 2025 commit (https://github.com/a2aproject/a2a). This schema exists to catch regressions in card generation; it is not the official A2A schema. Only the MUST-level fields from the spec are enforced here. Extra (additive) fields are allowed so the registry can evolve without breaking the schema — strictness on `required` is where the real protection lives.",

  "type": "object",
  "required": [
    "name",
    "version",
    "url",
    "capabilities",
    "defaultInputModes",
    "defaultOutputModes",
    "skills"
  ],
  "properties": {
    "name":             { "type": "string", "minLength": 1 },
    "description":      { "type": "string" },
    "version":          { "type": "string", "minLength": 1 },
    "url":              { "type": "string", "format": "uri" },
    "iconUrl":          { "type": "string", "format": "uri" },
    "documentationUrl": { "type": "string", "format": "uri" },

    "provider": {
      "type": "object",
      "required": ["organization"],
      "properties": {
        "organization": { "type": "string", "minLength": 1 },
        "url":          { "type": "string", "format": "uri" }
      }
    },

    "capabilities": {
      "type": "object",
      "description": "The A2A spec allows any of these flags to be omitted; when present they must be booleans.",
      "properties": {
        "streaming":              { "type": "boolean" },
        "pushNotifications":      { "type": "boolean" },
        "stateTransitionHistory": { "type": "boolean" },
        "extendedAgentCard":      { "type": "boolean" }
      }
    },

    "defaultInputModes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "defaultOutputModes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },

    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "tags"],
        "properties": {
          "id":          { "type": "string", "minLength": 1 },
          "name":        { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "tags": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "examples":    { "type": "array", "items": { "type": "string" } },
          "inputModes":  { "type": "array", "items": { "type": "string" } },
          "outputModes": { "type": "array", "items": { "type": "string" } }
        }
      }
    },

    "securitySchemes": {
      "type": "object",
      "description": "A2A delegates security scheme shapes to OpenAPI 3 (type: http | apiKey | oauth2 | openIdConnect). CLAUDE.md Resolved Decision K pins the allow-list to exactly those four. We enforce the type discriminator at the scheme level; deeper per-scheme shape is left to the unit tests on buildSecuritySchemes in internal/agents/card.go.",
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["http", "apiKey", "oauth2", "openIdConnect"]
          }
        }
      }
    }
  }
}
