# Backend API URL (server-side only — never exposed to the browser)
API_URL=http://localhost:8081

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-random-secret

# Keycloak OIDC provider
AUTH_KEYCLOAK_ID=ai-registry-web
AUTH_KEYCLOAK_SECRET=replace-me-with-client-secret
AUTH_KEYCLOAK_ISSUER=http://localhost:8080/realms/registry

# Must match the URL the browser uses to reach this app
NEXTAUTH_URL=http://localhost:3000
