# Copy this file to .env and fill in your values.
# Used by docker-compose for both the backend and web services.

# ── Auth (Next.js / Auth.js) ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=dev-secret-change-me-in-production

# Keycloak OIDC client credentials (matching keycloak-realm-dev.json)
AUTH_KEYCLOAK_ID=ai-registry-web
AUTH_KEYCLOAK_SECRET=change-me-in-production
# Must be reachable by BOTH the browser and the Next.js container.
# Add "127.0.0.1 keycloak" to /etc/hosts so the browser resolves this hostname.
AUTH_KEYCLOAK_ISSUER=http://keycloak:8080/realms/ai-registry
NEXTAUTH_URL=http://localhost:3000

# ── HTTP ──────────────────────────────────────────────────────────────────────
HTTP_ADDR=:8081
HTTP_READ_TIMEOUT=30s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=120s

# Comma-separated list of allowed CORS origins (empty = deny cross-origin)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://registry:registry@postgres:5432/registry?sslmode=disable
DATABASE_MAX_CONNS=25
DATABASE_MIN_CONNS=5

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=ai-registry-backend
OTEL_SERVICE_VERSION=0.1.0
# Set to your collector endpoint to enable OTLP trace export.
# Leave blank to use Prometheus-only metrics (no trace export).
OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317

# ── OIDC (backend token validation) ──────────────────────────────────────────
OIDC_ISSUER=http://keycloak:8080/realms/ai-registry

# ── Logging ───────────────────────────────────────────────────────────────────
# One of: debug, info, warn, error
LOG_LEVEL=info
