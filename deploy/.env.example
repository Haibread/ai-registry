# ============================================================================
# AI Registry — server configuration reference
# ============================================================================
# Copy this file to .env (or a location of your choice) and fill in the
# required values marked with [REQUIRED].
#
# Precedence (highest first):
#   1. Environment variable
#   2. YAML config file (set CONFIG_FILE or pass --config to the binary)
#   3. Built-in default shown in this file
#
# YAML config file key names mirror the env var names in snake_case, grouped
# by section.  See deploy/config.example.yaml for the YAML equivalent.
# ============================================================================

# ── Config file location ─────────────────────────────────────────────────────
# Path to an optional YAML config file. When set, values in the file override
# built-in defaults but are still overridden by individual env vars.
# CONFIG_FILE=

# ── HTTP server ───────────────────────────────────────────────────────────────
# Address and port the HTTP server listens on.
HTTP_ADDR=:8081

# Timeouts for HTTP connections (Go duration strings: 30s, 2m, …).
HTTP_READ_TIMEOUT=30s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=120s

# Comma-separated list of allowed CORS origins for the API.
# Example: http://localhost:3000,https://registry.example.com
CORS_ALLOWED_ORIGINS=

# CIDR of the trusted reverse proxy, used to extract the real client IP from
# X-Forwarded-For when rate-limiting.  Leave empty if there is no proxy.
# Example: 10.0.0.0/8
TRUSTED_PROXY_CIDR=

# ── Database ──────────────────────────────────────────────────────────────────
# [REQUIRED] PostgreSQL connection string.
DATABASE_URL=postgres://user:password@host:5432/ai_registry?sslmode=disable

# Connection pool sizes.
DATABASE_MAX_CONNS=25
DATABASE_MIN_CONNS=5

# ── Authentication (OIDC / Keycloak) ─────────────────────────────────────────
# [REQUIRED] OIDC issuer URL — must match the `iss` claim in issued JWTs.
# For a browser SPA this is the public-facing Keycloak URL.
# Example: http://keycloak:8080/realms/ai-registry
OIDC_ISSUER=

# Override the URL used to fetch the JWKS (public keys).  Set this when the
# server container cannot reach the public issuer URL directly.
# Example: http://keycloak:8080/realms/ai-registry/protocol/openid-connect/certs
OIDC_JWKS_URL=

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
# Service name reported in traces and metrics.
OTEL_SERVICE_NAME=ai-registry-server

# Service version reported in traces and metrics.
OTEL_SERVICE_VERSION=0.1.0

# OTLP gRPC endpoint for exporting traces (e.g. an OTel Collector).
# Leave empty to disable OTLP export and rely on the Prometheus /metrics
# endpoint only.
# Example: http://otel-collector:4317
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Logging ───────────────────────────────────────────────────────────────────
# Structured log level: debug | info | warn | error
LOG_LEVEL=info
