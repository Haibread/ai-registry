# Dev environment — do NOT commit real secrets.

# ── Auth (frontend OIDC — kept for reference, not used by backend) ───────────
# VITE_OIDC_ISSUER and VITE_OIDC_CLIENT_ID are passed as Docker build args.

# ── HTTP ──────────────────────────────────────────────────────────────────────
HTTP_ADDR=:8081
HTTP_READ_TIMEOUT=30s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=120s

# Comma-separated list of allowed CORS origins (empty = deny cross-origin)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://registry:registry@postgres:5432/registry?sslmode=disable
DATABASE_MAX_CONNS=25
DATABASE_MIN_CONNS=5

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=ai-registry-server
OTEL_SERVICE_VERSION=0.1.0
# Set to your collector endpoint to enable OTLP trace export.
# Leave blank to use Prometheus-only metrics (no trace export).
# Uncomment when running with the observability profile: --profile observability
# OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317

# ── OIDC (server token validation) ───────────────────────────────────────────
# OIDC_ISSUER must match the `iss` claim in JWTs — the browser-visible URL.
OIDC_ISSUER=http://localhost:8080/realms/ai-registry
# OIDC_JWKS_URL overrides the JWKS fetch URL so the server (inside Docker)
# can reach Keycloak via its internal hostname instead of localhost.
OIDC_JWKS_URL=http://keycloak:8080/realms/ai-registry/protocol/openid-connect/certs

# ── Logging ───────────────────────────────────────────────────────────────────
# One of: debug, info, warn, error
LOG_LEVEL=info
